rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Admin helper - check role in users collection
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      // Saved Posts Subcollection
      match /savedPosts/{postId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && incoming().postId == postId;
        allow delete: if isOwner(userId);
      }

      // Wishlist Subcollection
      match /wishlist/{productId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && incoming().productId == productId;
        allow delete: if isOwner(userId);
      }
    }

    // Marketplace Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      // Product Reviews
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().productId == productId;
        allow update: if isSignedIn() && isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['comment', 'rating', 'updatedAt']);
        allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      }
    }

    // Order Records
    match /orders/{orderId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Community Social Posts
    match /posts/{postId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Action: Interaction (Like)
        (incoming().diff(existing()).affectedKeys().hasAny(['likes', 'likedBy']) && incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likedBy'])) ||
        // Action: Edit Content
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt'])) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      
      // Post Comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid && incoming().postId == postId;
        allow update: if isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']);
        allow delete: if isOwner(existing().authorId) || isAdmin();
      }
    }
    // Newsletter
    match /newsletter/{docId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Promotions / Ads (Beeksiisa)
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Academy Books & Materials
    match /academy_books/{bookId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().uploaderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.uploaderId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.uploaderId == request.auth.uid || isAdmin());
    }
  }
}
